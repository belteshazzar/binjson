{
  "name": "@belteshazzar/binjson",
  "version": "1.1.1",
  "description": "A compact binary encoding format for JSON data with support for Origin Private File System (OPFS) in browsers",
  "main": "src/binjson.js",
  "type": "module",
  "exports": {
    ".": "./src/binjson.js",
    "./wasm": "./src/binjson-wasm.js",
    "./db": "./src/db.js",
    "./db-shared": "./src/db-coordinator.js"
  },
  "bin": {
    "binjson": "bin/binjson.js",
    "bplustree": "bin/bplustree.js",
    "rtree": "bin/rtree.js",
    "textindex": "bin/textindex.js",
    "textlog": "bin/textlog.js",
    "db": "bin/db.js"
  },
  "files": [
    "src",
    "bin",
    "lib",
    "c"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.js",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "build:worker": "rollup -c rollup.config.js && cp lib/binjson.wasm site/binjson.wasm",
    "build:wasm": "./c/build-wasm.sh",
    "build:native": "./c/build-native.sh",
    "prepack": "npm run build:wasm",
    "test:wasm": "node c/test-wasm.mjs",
    "test:c": "cc -std=c11 -Wall -Wextra -Werror c/binjson.c c/test_binjson.c -o /tmp/bjtest && /tmp/bjtest",
    "test:native": "cc -std=c11 -Wall -Wextra -Werror -Ic c/test_posixio.c c/posixio.c c/binjson.c c/bjfile.c c/bplustree.c -o /tmp/test_posixio && /tmp/test_posixio",
    "serve": "http-server -c-1 . -p 8083"
  },
  "keywords": [
    "binary",
    "json",
    "encoding",
    "opfs",
    "storage",
    "mongodb",
    "objectid",
    "serialization"
  ],
  "author": "",
  "license": "BSD-2-Clause",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "http-server": "^14.1.1",
    "node-opfs": "^1.0.0",
    "playwright": "^1.49.1",
    "rollup": "^4.31.0",
    "stemmer": "^2.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@playwright/test": "^1.61.1"
  }
}
